{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/settings", "destination": "/api/client?action=settings" },
    { "source": "/api/profile", "destination": "/api/client?action=profile" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "functions": {
    "api/report.js": { "maxDuration": 10 },
    "api/admin/measure.js": { "maxDuration": 10 },
    "api/cron/weekly-scores.js": { "maxDuration": 120 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "crons": [
    { "path": "/api/cron/weekly-scores", "schedule": "0 22 * * 6" },
    { "path": "/api/cron/daily-scores", "schedule": "0 13 * * *" }
  ]
}
