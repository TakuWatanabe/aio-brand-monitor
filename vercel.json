{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-scores",
      "schedule": "0 22 * * 6"
    },
    {
      "path": "/api/cron/daily-scores",
      "schedule": "0 13 * * *"
    }
  ]
}
